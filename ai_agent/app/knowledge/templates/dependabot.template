# Dependabot Configuration for {{repo_name}}
# This file enables automated dependency updates.
# Learn more: https://docs.github.com/en/code-security/dependabot/dependabot-version-updates

version: 2
updates:
{{#if has_npm}}
  # JavaScript/Node.js dependencies (npm/yarn)
  - package-ecosystem: "npm"
    directory: "/"
    schedule:
      interval: "weekly"
      day: "monday"
    open-pull-requests-limit: 10
    commit-message:
      prefix: "deps(npm):"
    labels:
      - "dependencies"
      - "javascript"
{{/if}}

{{#if has_pip}}
  # Python dependencies (pip/pipenv/poetry)
  - package-ecosystem: "pip"
    directory: "/"
    schedule:
      interval: "weekly"
      day: "monday"
    open-pull-requests-limit: 10
    commit-message:
      prefix: "deps(python):"
    labels:
      - "dependencies"
      - "python"
{{/if}}

{{#if has_docker}}
  # Docker base images
  - package-ecosystem: "docker"
    directory: "/"
    schedule:
      interval: "weekly"
    commit-message:
      prefix: "deps(docker):"
    labels:
      - "dependencies"
      - "docker"
{{/if}}

  # GitHub Actions
  - package-ecosystem: "github-actions"
    directory: "/"
    schedule:
      interval: "weekly"
    commit-message:
      prefix: "deps(actions):"
    labels:
      - "dependencies"
      - "ci"
